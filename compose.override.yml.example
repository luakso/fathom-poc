# Copy to compose.override.yml for local-only tweaks.
# Examples below — keep what you need, delete the rest.

services:
  base-collector:
    # Mount source for fast iteration without rebuild:
    # volumes:
    #   - .:/src:ro
    environment:
      LOG_LEVEL: debug

  postgres:
    # Expose on a different host port:
    # ports:
    #   - "5433:5432"

# Run base-collector backfill on demand (does NOT auto-start):
#   docker compose run --rm base-collector backfill --from-block 36334720
#
# Or via justfile:
#   just run base-collector backfill --from-block 36334720
