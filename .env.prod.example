# Fathom PRODUCTION environment.
# Copy to .env.prod on the box, fill real values, then: chmod 600 .env.prod
# NEVER commit .env.prod (it is gitignored).

# --- Postgres ---
# NOTE: deploy.sh sources this file via the shell (set -a; . ./.env.prod), so keep
# POSTGRES_PASSWORD free of shell-special characters ($ ` " ' \ space). Use a long
# alphanumeric value (e.g. `openssl rand -hex 24`) and the same value in DB_URL below.
POSTGRES_USER=fathom
POSTGRES_PASSWORD=CHANGE_ME_STRONG_SECRET
POSTGRES_DB=fathom

# In-network connection URL used by the binaries + init-db.
# Host is the compose service name "postgres" (NOT localhost — prod exposes no port).
DB_URL=postgres://fathom:CHANGE_ME_STRONG_SECRET@postgres:5432/fathom?sslmode=disable

# --- App ---
APP_ENV=prod
# Image tag to deploy. "latest" = newest main build.
# Pin to a git SHA for reproducible deploys / rollback (FATHOM_TAG=<sha> ./deploy.sh).
FATHOM_TAG=latest

# --- Base collector ---
BASE_HYPERSYNC_URL=https://base.hypersync.xyz
BASE_HYPERSYNC_BEARER_TOKEN=

# --- Caddy / serving ---
# No domain yet -> serve plain HTTP on :80. When you register a domain, set it here
# (e.g. FATHOM_DOMAIN=data.example.com) and Caddy auto-provisions HTTPS via Let's Encrypt.
FATHOM_DOMAIN=:80

# --- Postgres tuning (defaults suit a ~4GB box; raise on bigger boxes) ---
# temp_file_limit is the safety valve: a runaway analytical scan is killed instead
# of filling the disk and taking Docker down.
PG_SHARED_BUFFERS=1GB
PG_WORK_MEM=64MB
PG_MAINTENANCE_WORK_MEM=512MB
PG_EFFECTIVE_CACHE_SIZE=3GB
PG_TEMP_FILE_LIMIT=20GB
